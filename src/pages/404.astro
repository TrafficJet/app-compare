---
import Base from '../layouts/Base.astro';
---
<Base title="Page Not Found | AppCompare" description="The page you're looking for doesn't exist.">
  <div class="text-center py-24">
    <h1 class="text-6xl font-bold text-blue-700 mb-4">404</h1>
    <p class="text-xl text-gray-600 mb-8">This page doesn't exist.</p>
    <a href="/" class="inline-block bg-blue-700 text-white px-8 py-3 rounded-lg font-semibold hover:bg-blue-800 transition">
      Back to Home
    </a>
    <div class="mt-10 flex gap-4 justify-center text-sm">
      <a href="/compare/" class="text-blue-600 hover:underline">Compare Apps</a>
      <a href="/blog/" class="text-blue-600 hover:underline">Blog</a>
      <a href="/about/" class="text-blue-600 hover:underline">About</a>
    </div>
  </div>
</Base>

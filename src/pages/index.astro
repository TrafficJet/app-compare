---
import Base from '../layouts/Base.astro';
---
<Base
  title="Compare Shopify Apps Side by Side — AppCompare.com"
  description="Find the best Shopify apps for email marketing, product reviews, subscriptions, and more. Side-by-side comparisons with real pricing and ratings."
>
  <section class="text-center py-12">
    <h1 class="text-4xl font-bold mb-4">Compare Shopify Apps Side by Side</h1>
    <p class="text-lg text-gray-600 max-w-2xl mx-auto">
      Find the best apps for email marketing, reviews, subscriptions, and more — without the guesswork.
    </p>
    <a
      href="/compare"
      class="inline-block mt-8 px-6 py-3 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition"
    >
      Start Comparing Apps
    </a>
  </section>

  <section class="mt-4">
    <h2 class="text-2xl font-semibold mb-6 text-center">Featured Comparisons</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <a
        href="/compare"
        class="block border rounded-xl p-6 hover:shadow-md hover:border-blue-300 transition"
      >
        <div class="text-xs font-semibold text-blue-600 uppercase tracking-wide mb-2">Email Marketing</div>
        <h3 class="text-lg font-semibold mb-2">Klaviyo vs Omnisend vs Mailchimp</h3>
        <p class="text-gray-500 text-sm">
          Compare pricing, free plans, automation features, and which platform fits your store size.
        </p>
        <span class="inline-block mt-4 text-sm text-blue-600 font-medium">See comparison →</span>
      </a>

      <a
        href="/compare"
        class="block border rounded-xl p-6 hover:shadow-md hover:border-blue-300 transition"
      >
        <div class="text-xs font-semibold text-blue-600 uppercase tracking-wide mb-2">Product Reviews</div>
        <h3 class="text-lg font-semibold mb-2">Judge.me vs Stamped vs Yotpo</h3>
        <p class="text-gray-500 text-sm">
          Find the right review app by price, feature depth, and compatibility with your store theme.
        </p>
        <span class="inline-block mt-4 text-sm text-blue-600 font-medium">See comparison →</span>
      </a>

      <a
        href="/compare"
        class="block border rounded-xl p-6 hover:shadow-md hover:border-blue-300 transition"
      >
        <div class="text-xs font-semibold text-blue-600 uppercase tracking-wide mb-2">Subscriptions</div>
        <h3 class="text-lg font-semibold mb-2">Recharge vs Bold vs Seal</h3>
        <p class="text-gray-500 text-sm">
          Compare subscription app costs, features, and which works best for your business model.
        </p>
        <span class="inline-block mt-4 text-sm text-blue-600 font-medium">See comparison →</span>
      </a>
    </div>
  </section>

  <section class="mt-16 bg-blue-50 rounded-2xl p-8 text-center">
    <h2 class="text-2xl font-semibold mb-3">Not sure which app to choose?</h2>
    <p class="text-gray-600 mb-6">
      Use our interactive comparison tool to select any two apps and view a detailed side-by-side breakdown.
    </p>
    <a
      href="/compare"
      class="inline-block px-6 py-3 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition"
    >
      Open Comparison Tool
    </a>
  </section>
</Base>
